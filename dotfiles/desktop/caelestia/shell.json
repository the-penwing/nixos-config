        "workspaces": {
            "activeIndicator": true,
            "maxWindowIcons": 5,
            "occupiedBg": true,
            "perMonitorWorkspaces": true,
            "showWindows": true,
            "shown": 5
        }
    },
    "border": {
        "rounding": 18,
        "thickness": 8
    },
