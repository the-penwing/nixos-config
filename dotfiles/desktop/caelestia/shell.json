{
    "appearance": {
        "anim": {
            "durations": {
                "scale": 1
            }
        },
        "font": {
            "family": {
                "mono": "CaskaydiaCove NF",
                "sans": "Cantarell"
            },
            "size": {
                "scale": 0.85
            }
        },
        "padding": {
            "scale": 0.7
        },
        "rounding": {
            "scale": 1
        },
        "spacing": {
            "scale": 0.85
        },
        "transparency": {
            "enabled": false
        }
    },
    "background": {
        "desktopClock": {
            "background": {
                "enabled": true
            },
            "enabled": true,
            "shadow": {
                "enabled": false
            }
        },
        "visualiser": {
            "autoHide": true,
            "enabled": true
        }
    },
    "bar": {
        "activeWindow": {
            "compact": false,
            "inverted": false
        },
        "clock": {
            "background": true,
            "showDate": true,
            "showIcon": false
        },
        "persistent": true,
        "showOnHover": true,
        "status": {
            "showAudio": true,
            "showBattery": true,
            "showLockStatus": false,
            "showNetwork": true,
            "showWifi": true
        },
        "tray": {
            "background": true,
            "compact": false,
            "recolour": false
        },
        "workspaces": {
            "activeIndicator": true,
            "maxWindowIcons": 5,
            "occupiedBg": true,
            "perMonitorWorkspaces": true,
            "showWindows": false,
            "shown": 5
        }
    },
    "border": {
        "rounding": 18,
        "thickness": 8
    },
    "general": {
        "apps": {
            "audio": [
                "pavucontrol"
            ],
            "explorer": [
                "thunar"
            ],
            "playback": [
                "mpv"
            ],
            "terminal": [
                "ghostty"
            ]
        }
    },
    "launcher": {
        "enableDangerousActions": false,
        "favouriteApps": [],
        "hiddenApps": [
            "nm-connection-editor",
            "blueman-adapters",
            "blueman-manager",
            "thunar-bulk-rename",
            "btop",
            "org.pulseaudio.pavucontrol",
            "vim",
            "syncthing-ui",
            "qt6ct",
            "nvim",
            "micro",
            "cups",
            "kvantummanager",
            "gvim",
            "nwg-look",
            "nwg-displays",
            "thunar-settings"
        ]
    },
    "notifs": {
        "openExpanded": false
    },
    "utilities": {
        "vpn": {
            "provider": [
                {
                    "displayName": "Tailscale",
                    "enabled": true,
                    "interface": "tailscale0",
                    "name": "tailscale"
                }
            ]
        }
    }
}
