{
    "appearance": {
        "anim": {
            "durations": {
                "scale": 1
            }
        },
        "font": {
            "family": {
                "material": "Material Symbols Sharp",
                "mono": "0xProto Nerd Font Mono",
                "sans": "Cantarell"
            },
            "size": {
                "scale": 0.85
            }
        },
        "padding": {
            "scale": 0.7
        },
        "rounding": {
            "scale": 1
        },
        "spacing": {
            "scale": 0.85
        },
        "transparency": {
            "base": 0.65,
            "enabled": false,
            "layers": 0.5
        }
    },
    "background": {
        "desktopClock": {
            "background": {
                "enabled": true
