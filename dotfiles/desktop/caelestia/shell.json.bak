{
    "appearance": {
        "font": {
            "family": {
                "mono": "CaskaydiaCove NF",
                "sans": "Cantarell"
            }
        },
        "transparency": {
            "enabled": false
        }
    },
    "background": {
        "desktopClock": {
            "background": {
                "enabled": false
            }
        }
    },
    "bar": {
        "activeWindow": {
            "compact": false,
            "inverted": false
        },
        "clock": {
            "background": true,
            "showDate": true
        },
        "status": {
            "showAudio": true,
            "showBattery": true,
            "showLockStatus": false,
            "showNetwork": true,
            "showWifi": true
        },
        "tray": {
            "background": true,
            "compact": false,
            "recolour": false
        },
        "workspaces": {
            "activeIndicator": true,
            "maxWindowIcons": 4,
            "occupiedBg": false,
            "perMonitorWorkspaces": true,
            "showWindows": false,
            "shown": 4
        }
    },
    "general": {
        "apps": {
            "audio": [
                "pavucontrol"
            ],
            "explorer": [
                "thunar"
            ],
            "playback": [
                "mpv"
            ],
            "terminal": [
                "ghostty"
            ]
        }
    },
    "launcher": {
        "enableDangerousActions": false,
        "favouriteApps": [
        ],
        "hiddenApps": [
            "nm-connection-editor",
            "blueman-adapters",
            "blueman-manager",
            "thunar-bulk-rename",
            "btop",
            "waypaper",
            "org.pulseaudio.pavucontrol",
            "vim",
            "syncthing-ui",
            "rofi-theme-selector",
            "rofi",
            "qt6ct",
            "networkmanager_dmenu",
            "nvim",
            "micro",
            "cups",
            "kvantummanager",
            "gvim",
            "nwg-look",
            "nwg-displays",
            "thunar-settings"
        ]
    },
    "notifs": {
        "openExpanded": false
    }
}
