#!/usr/bin/env bash
#
# Unified config sync script for dotfiles.
#
# Syncs configuration from dotfiles/ to their destinations in ~/.config, ~/.zshrc, etc.
# Supports both pull (dotfiles → config) and push (config → dotfiles).
#
# Usage:
#   ./scripts/sync-config pull    # Sync from dotfiles to config (default)
#   ./scripts/sync-config push    # Sync from config back to dotfiles
#

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Define sync pairs: source in dotfiles/ → destination in ~/.config, ~, etc.
# Format: "dotfiles_path:config_path"
declare -a SYNC_PAIRS=(
  "dotfiles/editor/nvim:~/.config/nvim"
  "dotfiles/desktop/hyprland:~/.config/hypr"
  "dotfiles/desktop/caelestia:~/.config/caelestia"
  "dotfiles/apps/ghostty:~/.config/ghostty"
  "dotfiles/apps/btop:~/.config/btop"
  "dotfiles/apps/fastfetch:~/.config/fastfetch"
  "dotfiles/apps/yazi:~/.config/yazi"
  "dotfiles/shell/zsh/.zshrc:~/.zshrc"
  "dotfiles/shell/zsh/zshrc.d:~/.config/zsh/zshrc.d"
  "dotfiles/shell/tmux/.tmux.conf:~/.tmux.conf"
  "dotfiles/shell/starship.toml:~/.config/starship.toml"
  "dotfiles/theme/gtk-3.0:~/.config/gtk-3.0"
)

ACTION="${1:-pull}"

# Validate action
if [[ "$ACTION" != "pull" && "$ACTION" != "push" ]]; then
  echo "❌ Invalid action: $ACTION. Use 'pull' or 'push'."
  exit 1
fi

sync_pair() {
  local src="$1"
  local dst="$2"

  # Expand ~ to $HOME
  dst="${dst/#\~/$HOME}"
  src="${REPO_ROOT}/${src}"

  # Check source exists
  if [ ! -e "$src" ]; then
    echo "  ⚠️  Source does not exist: $src"
    return
  fi

  if [ "$ACTION" = "pull" ]; then
    # dotfiles → config
    mkdir -p "$(dirname "$dst")"
    if [ -d "$src" ]; then
      mkdir -p "$dst"
      echo "  ← $src → $dst"
      rsync -a --delete "$src"/ "$dst"/ 2>&1 | grep -v "^$" || true
    else
      echo "  ← $src → $dst"
      cp "$src" "$dst"
    fi
    chmod -R u+w "$dst" 2>/dev/null || true
  elif [ "$ACTION" = "push" ]; then
    # config → dotfiles
    if [ ! -e "$dst" ]; then
      echo "  ⚠️  Destination does not exist: $dst"
      return
    fi
    mkdir -p "$(dirname "$src")"
    if [ -d "$dst" ]; then
      mkdir -p "$src"
      echo "  → $dst → $src"
      rsync -a --delete "$dst"/ "$src"/ 2>&1 | grep -v "^$" || true
    else
      echo "  → $dst → $src"
      cp "$dst" "$src"
    fi
  fi
}

echo "=== Config Sync: $ACTION ==="
for pair in "${SYNC_PAIRS[@]}"; do
  IFS=: read -r src dst <<<"$pair"
  sync_pair "$src" "$dst"
done

echo "✅ Sync complete: $ACTION"
