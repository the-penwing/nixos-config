#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SRC_DIR="${REPO_ROOT}/dotfiles/shell/zsh/zshrc.d"
DST_DIR="${HOME}/.config/zsh/zshrc.d"

# Check if source directory exists
if [ ! -d "$SRC_DIR" ]; then
  echo "❌ Source directory not found: $SRC_DIR"
  exit 1
fi

# Create destination directory
mkdir -p "$DST_DIR"

# Copy all .zsh files
if [ "$(find "$SRC_DIR" -maxdepth 1 -name "*.zsh" -type f | wc -l)" -eq 0 ]; then
  echo "❌ No .zsh files found in $SRC_DIR"
  exit 1
fi

cp -v "$SRC_DIR"/*.zsh "$DST_DIR/"

echo "✅ Copied $(ls "$SRC_DIR"/*.zsh | wc -l) zshrc.d files to $DST_DIR"

# Verify files are readable
for file in "$DST_DIR"/*.zsh; do
  if [ ! -r "$file" ]; then
    echo "❌ File not readable: $file"
    exit 1
  fi
done

echo "✅ All files are readable"
